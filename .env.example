# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.onrender.com

# CSRF Trusted Origins (comma-separated, include scheme)
CSRF_TRUSTED_ORIGINS=https://yourdomain.onrender.com,http://localhost

# Database Configuration (use DATABASE_URL for Render)
# DATABASE_URL=postgres://user:password@host:port/dbname
DB_NAME=photo_manager
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
USE_CLOUDINARY=True

# Security Settings
SECURE_SSL_REDIRECT=True
